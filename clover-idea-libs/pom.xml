    <artifactId>clover-idea-libs</artifactId>
    <version>213.7172.25</version> <!-- major.minor.build (2021.3.3 build IC-213.7172.25) -->
    <packaging>pom</packaging>
    <description>
        This module prepares a subset of IntelliJ IDEA's JAR files as Maven artifacts, using a downloaded
        IntelliJ IDEA distribution and installing them locally as Maven artifacts. This installation needs
        to be executed only once, during workspace setup (-Pworkspace-setup). Import clover-idea-all artifact
        to get these dependencies.
    </description>
    <licenses>
        <license>
            <name>JetBrains (Commercial License)</name>
            <url>https://www.jetbrains.com/idea/buy/license.html</url>
        </license>
    </licenses>
    <name>IDEA Libraries Packaging and Installation</name>
    <modules>
        <module>clover-idea-all</module>
    </modules>
    <profiles>
        <profile>
            <id>workspace-setup</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.0.0</version>
                        <executions>
                            <execution>
                                <phase>generate-resources</phase>
                                <goals>
                                    <goal>run</goal>
                                </goals>
                                <configuration>
                                    <target>
                                        <!-- download -->
                                        <echo message="Downloading IDEA ..."/>
                                        <mkdir dir="${project.build.directory}/download"/>
                                        <get src="${idea.download.site}/${idea.download.path}/${idea.download.file}"
                                             dest="${project.build.directory}/download/${idea.download.file}"
                                             skipexisting="true"/>

                                        <!-- extract -->
                                        <echo message="Unpacking IDEA archive ..."/>
                                        <mkdir dir="${project.build.directory}/extract"/>
                                        <untar src="${project.build.directory}/download/${idea.download.file}"
                                               dest="${project.build.directory}/extract"
                                               compression="gzip"/>

                                        <!-- pack again into zip -->
                                        <zip destfile="${project.build.directory}/merge/idea.zip"
                                             basedir="${project.build.directory}/extract/${idea.download.dir}"
                                             includes="bin/**,lib/*.jar,plugins/devkit/**,plugins/properties/**">
                                        </zip>
                                    </target>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-install-plugin</artifactId>
                        <version>3.1.1</version>
                        <executions>
