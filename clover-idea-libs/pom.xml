                                <phase>install</phase>
                                <goals>
                                    <goal>install-file</goal>
                                </goals>
                                <configuration>
                                    <file>${project.build.directory}/merge/idea.zip</file>
                                    <groupId>org.openclover.idea.libs</groupId>
                                    <artifactId>idea-zip</artifactId>
                                    <version>${project.version}</version>
                                    <packaging>zip</packaging>
                                </configuration>
                            </execution>

