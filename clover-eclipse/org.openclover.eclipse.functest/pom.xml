<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.openclover</groupId>
        <artifactId>clover-eclipse</artifactId>
        <version>5.0.0.v20260701000000</version>
    </parent>
    <artifactId>org.openclover.eclipse.functest</artifactId>
    <packaging>pom</packaging>
    <name>OpenClover Eclipse Functional Tests</name>

    <properties>
        <!-- Eclipse download coordinates; override per matrix entry on CI -->
        <eclipse.download.path>technology/epp/downloads/release/${eclipse.version}/R</eclipse.download.path>
        <eclipse.download.site>https://ftp.fau.de/eclipse</eclipse.download.site>

        <!-- Paths to previously-built artifacts; override on CI (artifacts downloaded separately) -->
        <clover.site.zip>${project.basedir}/../org.openclover.eclipse.updatesite/target/clover-eclipse-site-${project.version}.zip</clover.site.zip>
        <clover.runner.jar.dir>${project.basedir}/../org.openclover.eclipse.functest.runner/target</clover.runner.jar.dir>
        <!-- clover-runtime version (parent group, not eclipse-versioned) -->
        <clover.base.version>5.0.0-SNAPSHOT</clover.base.version>
        <clover.runtime.jar>${project.basedir}/../../clover-runtime/target/clover-runtime-${clover.base.version}.jar</clover.runtime.jar>

        <!-- Internal paths (not overridden) -->
        <eclipse.install.dir>${project.build.directory}/eclipse-install</eclipse.install.dir>
        <eclipse.site.dir>${project.build.directory}/eclipse-site</eclipse.site.dir>

        <!--
            OS-specific properties set by the auto-activated os-* profiles below:
              eclipse.download.file         - archive filename
              eclipse.extract.type          - tar.gz | zip
              eclipse.install.marker        - subdir whose presence means Eclipse is extracted
              eclipse.exe                   - path to eclipse executable
              eclipse.destination           - p2 director -destination value
              eclipse.dropins.dir           - dropins directory for the runner JAR
              eclipse.functest.skip.xvfb    - true/false: run via xvfb-run (Linux)
              eclipse.functest.skip.direct  - true/false: run eclipse directly (macOS/Windows)
        -->
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-deploy-plugin</artifactId>
                <configuration>
                    <skip>true</skip>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>

        <!-- ============================================================
             OS-SPECIFIC PROFILES (auto-activated, properties only)
             ============================================================ -->

        <profile>
            <id>os-linux</id>
            <activation><os><name>Linux</name></os></activation>
            <properties>
                <eclipse.download.file>eclipse-java-${eclipse.version}-R-linux-gtk-x86_64.tar.gz</eclipse.download.file>
                <eclipse.extract.type>tar.gz</eclipse.extract.type>
                <eclipse.install.marker>eclipse</eclipse.install.marker>
                <eclipse.exe>${eclipse.install.dir}/eclipse/eclipse</eclipse.exe>
                <eclipse.destination>${eclipse.install.dir}/eclipse</eclipse.destination>
                <eclipse.dropins.dir>${eclipse.install.dir}/eclipse/dropins</eclipse.dropins.dir>
                <eclipse.functest.skip.xvfb>false</eclipse.functest.skip.xvfb>
                <eclipse.functest.skip.direct>true</eclipse.functest.skip.direct>
            </properties>
        </profile>

        <profile>
            <id>os-mac</id>
            <activation><os><family>mac</family></os></activation>
            <properties>
                <!-- ${os.arch} resolves to aarch64 on Apple Silicon, x86_64 on Intel -->
                <eclipse.download.file>eclipse-java-${eclipse.version}-R-macosx-cocoa-${os.arch}.tar.gz</eclipse.download.file>
                <eclipse.extract.type>tar.gz</eclipse.extract.type>
                <eclipse.install.marker>Eclipse.app</eclipse.install.marker>
                <eclipse.exe>${eclipse.install.dir}/Eclipse.app/Contents/MacOS/eclipse</eclipse.exe>
                <eclipse.destination>${eclipse.install.dir}/Eclipse.app/Contents/Eclipse</eclipse.destination>
                <eclipse.dropins.dir>${eclipse.install.dir}/Eclipse.app/Contents/Eclipse/dropins</eclipse.dropins.dir>
                <eclipse.functest.skip.xvfb>true</eclipse.functest.skip.xvfb>
                <eclipse.functest.skip.direct>false</eclipse.functest.skip.direct>
            </properties>
        </profile>

        <profile>
            <id>os-windows</id>
            <activation><os><family>windows</family></os></activation>
            <properties>
                <eclipse.download.file>eclipse-java-${eclipse.version}-R-win32-x86_64.zip</eclipse.download.file>
                <eclipse.extract.type>zip</eclipse.extract.type>
                <eclipse.install.marker>eclipse</eclipse.install.marker>
                <eclipse.exe>${eclipse.install.dir}/eclipse/eclipse.exe</eclipse.exe>
                <eclipse.destination>${eclipse.install.dir}/eclipse</eclipse.destination>
                <eclipse.dropins.dir>${eclipse.install.dir}/eclipse/dropins</eclipse.dropins.dir>
                <eclipse.functest.skip.xvfb>true</eclipse.functest.skip.xvfb>
                <eclipse.functest.skip.direct>false</eclipse.functest.skip.direct>
            </properties>
        </profile>

        <!-- ============================================================
             MAIN PROFILE — all plugin configuration lives here.
             Not auto-activated; combine with an os-* profile above.
             Usage: mvn verify -Peclipse-functest
                    [-Declipse.version=2025-06 ...]
             ============================================================ -->
        <profile>
            <id>eclipse-functest</id>
            <build>
                <plugins>

                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.0.0</version>
                        <executions>

                            <!-- 1–3. Download archive, extract Eclipse, unzip update site -->
                            <execution>
                                <id>download-and-extract-eclipse</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <mkdir dir="${project.build.directory}/download"/>
                                        <get src="${eclipse.download.site}/${eclipse.download.path}/${eclipse.download.file}"
                                             dest="${project.build.directory}/download/${eclipse.download.file}"
                                             skipexisting="true"/>

                                        <mkdir dir="${eclipse.install.dir}"/>
                                        <ant antfile="${project.basedir}/src/ant/download-eclipse.xml"
                                             target="extract-eclipse">
                                            <property name="eclipse.install.dir"       value="${eclipse.install.dir}"/>
                                            <property name="eclipse.install.marker"    value="${eclipse.install.marker}"/>
                                            <property name="eclipse.extract.type"      value="${eclipse.extract.type}"/>
                                            <property name="eclipse.download.file.path" value="${project.build.directory}/download/${eclipse.download.file}"/>
                                        </ant>
                                        <chmod file="${eclipse.exe}" perm="755"/>

                                        <mkdir dir="${eclipse.site.dir}"/>
                                        <unzip src="${clover.site.zip}"
                                               dest="${eclipse.site.dir}"
                                               overwrite="false"/>
                                    </target>
                                </configuration>
                            </execution>

                            <!-- 5. Copy functest runner JAR into dropins/ -->
                            <execution>
                                <id>copy-runner-jar</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <mkdir dir="${eclipse.dropins.dir}"/>
                                        <copy todir="${eclipse.dropins.dir}">
                                            <fileset dir="${clover.runner.jar.dir}" includes="*.jar"/>
                                        </copy>
                                    </target>
                                </configuration>
                            </execution>

                            <!-- 7. Preserve Eclipse workspace log for CI artifacts -->
                            <execution>
                                <id>archive-log</id>
                                <phase>post-integration-test</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <copy file="${project.build.directory}/functest-workspace/.metadata/.log"
                                              tofile="${project.build.directory}/eclipse-workspace.log"
                                              failonerror="false"/>
                                    </target>
                                </configuration>
                            </execution>

                        </executions>
                    </plugin>

                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>

                            <!-- 4. Install clover-eclipse feature via p2 director -->
                            <execution>
                                <id>p2-install-clover</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <executable>${eclipse.exe}</executable>
                                    <timeout>300000</timeout> <!-- 5 minutes -->
                                    <arguments>
                                        <argument>-nosplash</argument>
                                        <argument>-consolelog</argument>
                                        <argument>-application</argument>
                                        <argument>org.eclipse.equinox.p2.director</argument>
                                        <argument>-repository</argument>
                                        <argument>file://${eclipse.site.dir}</argument>
                                        <argument>-installIU</argument>
                                        <argument>org.openclover.eclipse.feature.feature.group</argument>
                                        <argument>-destination</argument>
                                        <argument>${eclipse.destination}</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                            <!-- 6a. Run functional tests — Linux: wrap with xvfb-run -->
                            <execution>
                                <id>run-functest-xvfb</id>
                                <phase>integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <skip>${eclipse.functest.skip.xvfb}</skip>
                                    <timeout>1800000</timeout> <!-- 30 minutes -->
                                    <executable>xvfb-run</executable>
                                    <arguments>
                                        <argument>${eclipse.exe}</argument>
                                        <argument>-nosplash</argument>
                                        <argument>-application</argument>
                                        <argument>org.openclover.eclipse.functest.runner.application</argument>
                                        <argument>-data</argument>
                                        <argument>${project.build.directory}/functest-workspace</argument>
                                        <argument>-projectsDir</argument>
                                        <argument>${project.basedir}/src/test/resources/projects</argument>
                                        <argument>-cloverRuntime</argument>
                                        <argument>${clover.runtime.jar}</argument>
                                        <argument>-reportsDir</argument>
                                        <argument>${project.build.directory}/surefire-reports</argument>
                                        <argument>-eclipseVersion</argument>
                                        <argument>${eclipse.version}</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                            <!-- 6b. Run functional tests — macOS/Windows: invoke eclipse directly -->
                            <execution>
                                <id>run-functest-direct</id>
                                <phase>integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <skip>${eclipse.functest.skip.direct}</skip>
                                    <timeout>1800000</timeout> <!-- 30 minutes -->
                                    <executable>${eclipse.exe}</executable>
                                    <arguments>
                                        <argument>-nosplash</argument>
                                        <argument>-application</argument>
                                        <argument>org.openclover.eclipse.functest.runner.application</argument>
                                        <argument>-data</argument>
                                        <argument>${project.build.directory}/functest-workspace</argument>
                                        <argument>-projectsDir</argument>
                                        <argument>${project.basedir}/src/test/resources/projects</argument>
                                        <argument>-cloverRuntime</argument>
                                        <argument>${clover.runtime.jar}</argument>
                                        <argument>-reportsDir</argument>
                                        <argument>${project.build.directory}/surefire-reports</argument>
                                        <argument>-eclipseVersion</argument>
                                        <argument>${eclipse.version}</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                        </executions>
                    </plugin>

                </plugins>
            </build>
        </profile>
    </profiles>
</project>
