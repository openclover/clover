<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.openclover</groupId>
        <artifactId>clover-eclipse</artifactId>
        <version>5.0.0.v20260701000000</version>
    </parent>
    <artifactId>org.openclover.eclipse.functest</artifactId>
    <packaging>pom</packaging>
    <name>OpenClover Eclipse Functional Tests</name>

    <properties>
        <!-- Eclipse download coordinates; override per matrix entry on CI -->
        <eclipse.download.path>technology/epp/downloads/release/${eclipse.version}/R</eclipse.download.path>
        <eclipse.download.site>https://ftp.fau.de/eclipse</eclipse.download.site>

        <!-- Paths to previously-built artifacts; override on CI (artifacts downloaded separately) -->
        <clover.site.zip>${project.basedir}/../org.openclover.eclipse.updatesite/target/clover-eclipse-site-${project.version}.zip</clover.site.zip>
        <clover.runner.jar.dir>${project.basedir}/../org.openclover.eclipse.functest.runner/target</clover.runner.jar.dir>
        <!-- clover-runtime version (parent group, not eclipse-versioned) -->
        <clover.base.version>5.0.0-SNAPSHOT</clover.base.version>
        <clover.runtime.jar>${project.basedir}/../../clover-runtime/target/clover-runtime-${clover.base.version}.jar</clover.runtime.jar>

        <!-- Internal paths (not overridden) -->
        <eclipse.install.dir>${project.build.directory}/eclipse-install</eclipse.install.dir>
        <eclipse.site.dir>${project.build.directory}/eclipse-site</eclipse.site.dir>

        <!--
            OS-specific properties set by the auto-activated os-* profiles below:
              eclipse.download.file         - archive filename
              eclipse.extract.type          - tar.gz | zip
              eclipse.install.marker        - subdir whose presence means Eclipse is extracted
              eclipse.exe                   - path to eclipse executable
              eclipse.destination           - p2 director -destination value
              eclipse.dropins.dir           - dropins directory for the runner JAR
              eclipse.functest.skip.xvfb    - true/false: run via xvfb-run (Linux)
              eclipse.functest.skip.direct  - true/false: run eclipse directly (macOS/Windows)
        -->
    </properties>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-deploy-plugin</artifactId>
                <configuration>
                    <skip>true</skip>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>

        <!-- ============================================================
             OS-SPECIFIC PROFILES (auto-activated, properties only)
             ============================================================ -->

        <profile>
            <id>os-linux</id>
            <activation><os><name>Linux</name></os></activation>
            <properties>
                <eclipse.download.file>eclipse-java-${eclipse.version}-R-linux-gtk-x86_64.tar.gz</eclipse.download.file>
                <eclipse.extract.type>tar.gz</eclipse.extract.type>
                <eclipse.install.marker>eclipse</eclipse.install.marker>
                <eclipse.exe>${eclipse.install.dir}/eclipse/eclipse</eclipse.exe>
                <eclipse.plugins.dir>${eclipse.install.dir}/eclipse/plugins</eclipse.plugins.dir>
                <eclipse.destination>${eclipse.install.dir}/eclipse</eclipse.destination>
                <eclipse.dropins.dir>${eclipse.install.dir}/eclipse/dropins</eclipse.dropins.dir>
                <eclipse.functest.skip.xvfb>false</eclipse.functest.skip.xvfb>
                <eclipse.functest.skip.direct>true</eclipse.functest.skip.direct>
            </properties>
        </profile>

        <profile>
            <id>os-mac</id>
            <activation><os><family>mac</family></os></activation>
            <properties>
                <!-- ${os.arch} resolves to aarch64 on Apple Silicon, x86_64 on Intel -->
                <eclipse.download.file>eclipse-java-${eclipse.version}-R-macosx-cocoa-${os.arch}.tar.gz</eclipse.download.file>
                <eclipse.extract.type>tar.gz</eclipse.extract.type>
                <eclipse.install.marker>Eclipse.app</eclipse.install.marker>
                <eclipse.exe>${eclipse.install.dir}/Eclipse.app/Contents/MacOS/eclipse</eclipse.exe>
                <eclipse.plugins.dir>${eclipse.install.dir}/Eclipse.app/Contents/Eclipse/plugins</eclipse.plugins.dir>
                <eclipse.destination>${eclipse.install.dir}/Eclipse.app/Contents/Eclipse</eclipse.destination>
                <eclipse.dropins.dir>${eclipse.install.dir}/Eclipse.app/Contents/Eclipse/dropins</eclipse.dropins.dir>
                <eclipse.functest.skip.xvfb>true</eclipse.functest.skip.xvfb>
                <eclipse.functest.skip.direct>false</eclipse.functest.skip.direct>
            </properties>
        </profile>

        <profile>
            <id>os-windows</id>
            <activation><os><family>windows</family></os></activation>
            <properties>
                <eclipse.download.file>eclipse-java-${eclipse.version}-R-win32-x86_64.zip</eclipse.download.file>
                <eclipse.extract.type>zip</eclipse.extract.type>
                <eclipse.install.marker>eclipse</eclipse.install.marker>
                <eclipse.exe>${eclipse.install.dir}/eclipse/eclipse.exe</eclipse.exe>
                <eclipse.plugins.dir>${eclipse.install.dir}/eclipse/plugins</eclipse.plugins.dir>
                <eclipse.destination>${eclipse.install.dir}/eclipse</eclipse.destination>
                <eclipse.dropins.dir>${eclipse.install.dir}/eclipse/dropins</eclipse.dropins.dir>
                <eclipse.functest.skip.xvfb>true</eclipse.functest.skip.xvfb>
                <eclipse.functest.skip.direct>false</eclipse.functest.skip.direct>
            </properties>
        </profile>

        <!-- ============================================================
             MAIN PROFILE — all plugin configuration lives here.
             Not auto-activated; combine with an os-* profile above.
             Usage: mvn verify -Peclipse-functest
                    [-Declipse.version=2025-06 ...]
             ============================================================ -->
        <profile>
            <id>eclipse-functest</id>
            <build>
                <plugins>

                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-antrun-plugin</artifactId>
                        <version>3.0.0</version>
                        <executions>

                            <!-- 1–3. Download archive, extract Eclipse, unzip update site -->
                            <execution>
                                <id>download-and-extract-eclipse</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <mkdir dir="${project.build.directory}/download"/>
                                        <get src="${eclipse.download.site}/${eclipse.download.path}/${eclipse.download.file}"
                                             dest="${project.build.directory}/download/${eclipse.download.file}"
                                             skipexisting="true"/>

                                        <mkdir dir="${eclipse.install.dir}"/>
                                        <ant antfile="${project.basedir}/src/ant/download-eclipse.xml"
                                             target="extract-eclipse">
                                            <property name="eclipse.install.dir"       value="${eclipse.install.dir}"/>
                                            <property name="eclipse.install.marker"    value="${eclipse.install.marker}"/>
                                            <property name="eclipse.extract.type"      value="${eclipse.extract.type}"/>
                                            <property name="eclipse.download.file.path" value="${project.build.directory}/download/${eclipse.download.file}"/>
                                        </ant>
                                        <chmod file="${eclipse.exe}" perm="755"/>

                                        <mkdir dir="${eclipse.site.dir}"/>
                                        <unzip src="${clover.site.zip}"
                                               dest="${eclipse.site.dir}"
                                               overwrite="false"/>
                                    </target>
                                </configuration>
                            </execution>

                            <!-- 5. Copy functest runner JAR into dropins/ -->
                            <execution>
                                <id>copy-runner-jar</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <mkdir dir="${eclipse.dropins.dir}"/>
                                        <copy todir="${eclipse.dropins.dir}">
                                            <fileset dir="${clover.runner.jar.dir}" includes="*.jar"/>
                                        </copy>
                                    </target>
                                </configuration>
                            </execution>

                            <!-- 7. Preserve Eclipse workspace logs for CI artifacts -->
                            <execution>
                                <id>archive-log</id>
                                <phase>post-integration-test</phase>
                                <goals><goal>run</goal></goals>
                                <configuration>
                                    <target>
                                        <copy file="${project.build.directory}/p2-workspace/.metadata/.log"
                                              tofile="${project.build.directory}/eclipse-p2-workspace.log"
                                              failonerror="false"/>
                                        <copy file="${project.build.directory}/functest-workspace/.metadata/.log"
                                              tofile="${project.build.directory}/eclipse-workspace.log"
                                              failonerror="false"/>
                                    </target>
                                </configuration>
                            </execution>

                        </executions>
                    </plugin>

                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>

                            <!-- 4. Start Xvfb virtual display in background (Linux only; macOS uses Cocoa) -->
                            <execution>
                                <id>start-xvfb</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <skip>${eclipse.functest.skip.xvfb}</skip>
                                    <executable>bash</executable>
                                    <timeout>30000</timeout>
                                    <arguments>
                                        <argument>-c</argument>
                                        <!-- Redirect Xvfb I/O to /dev/null so it doesn't hold Maven's stream open -->
                                        <argument>Xvfb :99 -screen 0 1280x1024x24 &lt;/dev/null &gt;/dev/null 2&gt;&amp;1 &amp; sleep 2 &amp;&amp; echo "[xvfb] display :99 ready"</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                            <!-- 4b. Verify display and environment before touching Eclipse (Linux only) -->
                            <execution>
                                <id>pre-check</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <skip>${eclipse.functest.skip.xvfb}</skip>
                                    <executable>bash</executable>
                                    <timeout>30000</timeout>
                                    <environmentVariables>
                                        <DISPLAY>:99</DISPLAY>
                                        <NO_AT_BRIDGE>1</NO_AT_BRIDGE>
                                        <GTK_A11Y>none</GTK_A11Y>
                                        <GDK_BACKEND>x11</GDK_BACKEND>
                                        <SWT_GTK3>1</SWT_GTK3>
                                        <LIBGL_ALWAYS_SOFTWARE>1</LIBGL_ALWAYS_SOFTWARE>
                                    </environmentVariables>
                                    <arguments>
                                        <argument>-c</argument>
                                        <argument>
                                            echo "=== Display ===" &amp;&amp;
                                            xdpyinfo -display :99 2&gt;&amp;1 | head -5 || echo "[WARN] xdpyinfo failed" ;
                                            echo "=== Eclipse binary ===" &amp;&amp;
                                            ls -la ${eclipse.exe} &amp;&amp; file ${eclipse.exe} ;
                                            echo "=== Native lib deps (last 20 lines) ===" &amp;&amp;
                                            ldd ${eclipse.exe} 2&gt;&amp;1 | tail -20 ;
                                            echo "=== eclipse.ini ===" &amp;&amp;
                                            cat ${eclipse.plugins.dir}/../eclipse.ini 2&gt;&amp;1 || true ;
                                            echo "=== Java ===" &amp;&amp;
                                            java -version 2&gt;&amp;1 ;
                                            echo "=== Env ===" &amp;&amp;
                                            env | grep -E 'DISPLAY|NO_AT|GTK|SWT|GDK|LIBGL|JAVA|HOME|DBUS' | sort
                                        </argument>
                                    </arguments>
                                </configuration>
                            </execution>

                            <!--
                                5. Install clover-eclipse feature via p2 director.

                                On Linux the native eclipse launcher binary links against
                                org.eclipse.equinox.launcher.gtk.linux.x86_64_*.so which initialises GTK
                                *before* the JVM starts.  On headless Ubuntu CI this causes a silent
                                5-minute hang with zero output.

                                Fix: bypass the native binary entirely on Linux and invoke the equinox
                                launcher JAR directly with 'java -jar'.  The JVM starts immediately,
                                SWT/GTK is never touched by the launcher (p2 director is headless), and
                                consolelog output flows to Maven's stream reader from the first line.

                                macOS/Windows use the native binary as before — no GTK on those platforms.
                            -->
                            <execution>
                                <id>p2-install-clover</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <!-- Linux only: java -jar equinox launcher, no native GTK binary -->
                                    <skip>${eclipse.functest.skip.xvfb}</skip>
                                    <executable>bash</executable>
                                    <timeout>300000</timeout>
                                    <environmentVariables>
                                        <DISPLAY>:99</DISPLAY>
                                        <NO_AT_BRIDGE>1</NO_AT_BRIDGE>
                                        <GTK_A11Y>none</GTK_A11Y>
                                        <GDK_BACKEND>x11</GDK_BACKEND>
                                        <SWT_GTK3>1</SWT_GTK3>
                                        <LIBGL_ALWAYS_SOFTWARE>1</LIBGL_ALWAYS_SOFTWARE>
                                    </environmentVariables>
                                    <arguments>
                                        <argument>-xc</argument>
                                        <argument>LAUNCHER=$(ls ${eclipse.plugins.dir}/org.eclipse.equinox.launcher_*.jar | head -1) &amp;&amp; echo "[p2] launcher: $LAUNCHER" &amp;&amp; exec java -jar "$LAUNCHER" -nosplash -consolelog -debug -data ${project.build.directory}/p2-workspace -application org.eclipse.equinox.p2.director -repository file://${eclipse.site.dir} -installIU org.openclover.eclipse.feature.feature.group -destination ${eclipse.destination}</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                            <execution>
                                <id>p2-install-clover-direct</id>
                                <phase>pre-integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <!-- macOS/Windows: native eclipse binary works fine (no GTK on those platforms) -->
                                    <skip>${eclipse.functest.skip.direct}</skip>
                                    <executable>bash</executable>
                                    <timeout>300000</timeout>
                                    <arguments>
                                        <argument>-xc</argument>
                                        <argument>exec ${eclipse.exe} -nosplash -consolelog -debug -data ${project.build.directory}/p2-workspace -application org.eclipse.equinox.p2.director -repository file://${eclipse.site.dir} -installIU org.openclover.eclipse.feature.feature.group -destination ${eclipse.destination}</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                            <!-- 6. Run functional tests — same Linux/non-Linux split as p2 above -->
                            <execution>
                                <id>run-functest</id>
                                <phase>integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <!-- Linux only: java -jar equinox launcher -->
                                    <skip>${eclipse.functest.skip.xvfb}</skip>
                                    <executable>bash</executable>
                                    <timeout>600000</timeout>
                                    <environmentVariables>
                                        <DISPLAY>:99</DISPLAY>
                                        <NO_AT_BRIDGE>1</NO_AT_BRIDGE>
                                        <GTK_A11Y>none</GTK_A11Y>
                                        <GDK_BACKEND>x11</GDK_BACKEND>
                                        <SWT_GTK3>1</SWT_GTK3>
                                        <LIBGL_ALWAYS_SOFTWARE>1</LIBGL_ALWAYS_SOFTWARE>
                                    </environmentVariables>
                                    <arguments>
                                        <argument>-xc</argument>
                                        <argument>LAUNCHER=$(ls ${eclipse.plugins.dir}/org.eclipse.equinox.launcher_*.jar | head -1) &amp;&amp; echo "[functest] launcher: $LAUNCHER" &amp;&amp; exec java -jar "$LAUNCHER" -nosplash -consolelog -debug -application org.openclover.eclipse.functest.runner.application -data ${project.build.directory}/functest-workspace -projectsDir ${project.basedir}/src/test/resources/projects -cloverRuntime ${clover.runtime.jar} -reportsDir ${project.build.directory}/surefire-reports -eclipseVersion ${eclipse.version}</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                            <execution>
                                <id>run-functest-direct</id>
                                <phase>integration-test</phase>
                                <goals><goal>exec</goal></goals>
                                <configuration>
                                    <!-- macOS/Windows: native eclipse binary -->
                                    <skip>${eclipse.functest.skip.direct}</skip>
                                    <executable>bash</executable>
                                    <timeout>600000</timeout>
                                    <arguments>
                                        <argument>-xc</argument>
                                        <argument>exec ${eclipse.exe} -nosplash -consolelog -debug -application org.openclover.eclipse.functest.runner.application -data ${project.build.directory}/functest-workspace -projectsDir ${project.basedir}/src/test/resources/projects -cloverRuntime ${clover.runtime.jar} -reportsDir ${project.build.directory}/surefire-reports -eclipseVersion ${eclipse.version}</argument>
                                    </arguments>
                                </configuration>
                            </execution>

                        </executions>
                    </plugin>

                </plugins>
            </build>
        </profile>
    </profiles>
</project>
