<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.openclover</groupId>
        <artifactId>clover-eclipse</artifactId>
        <version>5.0.2.v20260720000000</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    <artifactId>org.openclover.eclipse.updatesite</artifactId>
    <name>OpenClover Eclipse Update Site</name>
    <packaging>pom</packaging>
    <description>A p2 update site (software repository) for OpenClover for Eclipse.</description>

    <!-- Dependencies are declared to force reactor build order: all plugins/features
         must be built (and, for releases, signed) before p2-maven-plugin resolves them. -->
    <dependencies>
        <dependency>
            <groupId>org.openclover</groupId>
            <artifactId>org.openclover.eclipse.ant</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openclover</groupId>
            <artifactId>org.openclover.eclipse.ant.feature</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openclover</groupId>
            <artifactId>org.openclover.eclipse.branding</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openclover</groupId>
            <artifactId>org.openclover.eclipse.core</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openclover</groupId>
            <artifactId>org.openclover.eclipse.feature</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openclover</groupId>
            <artifactId>org.openclover.eclipse.runtime</artifactId>
            <version>${project.version}</version>
        </dependency>
        <dependency>
            <groupId>org.openclover</groupId>
            <artifactId>org.openclover.eclipse.testopt</artifactId>
            <version>${project.version}</version>
        </dependency>
    </dependencies>
    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <executions>
                    <execution>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>resources</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <!-- Generate the p2 repository (content.jar, artifacts.jar, p2.index, plugins/, features/, category.xml)
                 into target/repository/. The eclipse plugin/feature JARs are already valid OSGi bundles, so
                 no bnd re-wrapping happens; source/transitive are disabled. -->
            <plugin>
                <groupId>org.reficio</groupId>
                <artifactId>p2-maven-plugin</artifactId>
                <version>3.0.0</version>
                <executions>
                    <execution>
                        <id>generate-p2-site</id>
                        <phase>prepare-package</phase>
                        <goals>
                            <goal>site</goal>
                        </goals>
                        <configuration>
                            <!-- Resolved relative to ${project.basedir} by the plugin, so keep it relative -->
                            <categoryFileURL>target/classes/category.xml</categoryFileURL>
                            <artifacts>
                                <artifact>
                                    <id>org.openclover:org.openclover.eclipse.branding:${project.version}</id>
                                    <transitive>false</transitive>
                                </artifact>
                                <artifact>
                                    <id>org.openclover:org.openclover.eclipse.core:${project.version}</id>
                                    <transitive>false</transitive>
                                </artifact>
                                <artifact>
                                    <id>org.openclover:org.openclover.eclipse.ant:${project.version}</id>
                                    <transitive>false</transitive>
                                </artifact>
                                <artifact>
                                    <id>org.openclover:org.openclover.eclipse.runtime:${project.version}</id>
                                    <transitive>false</transitive>
                                </artifact>
                                <artifact>
                                    <id>org.openclover:org.openclover.eclipse.testopt:${project.version}</id>
                                    <transitive>false</transitive>
                                </artifact>
                            </artifacts>
                            <features>
                                <artifact>
                                    <id>org.openclover:org.openclover.eclipse.feature:${project.version}</id>
                                    <source>false</source>
                                    <transitive>false</transitive>
                                </artifact>
                                <artifact>
                                    <id>org.openclover:org.openclover.eclipse.ant.feature:${project.version}</id>
                                    <source>false</source>
                                    <transitive>false</transitive>
                                </artifact>
                            </features>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <!-- Package the p2 repository as an archived update site zip. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-assembly-plugin</artifactId>
                <executions>
                    <execution>
                        <id>package-site</id>
                        <phase>package</phase>
                        <goals>
                            <goal>single</goal>
                        </goals>
                        <configuration>
                            <finalName>clover-eclipse-site-${project.version}</finalName>
                            <appendAssemblyId>false</appendAssemblyId>
                            <descriptors>
                                <descriptor>src/assembly/clover-eclipse-site.xml</descriptor>
                            </descriptors>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-deploy-plugin</artifactId>
                <configuration>
                    <!-- The update site is uploaded to the website, not Maven Central -->
                    <skip>true</skip>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jarsigner-plugin</artifactId>
                <configuration>
                    <!-- This module produces a zip, not a plugin JAR; the plugin/feature
                         JARs are signed in their own modules before p2 consumes them. -->
                    <skip>true</skip>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>