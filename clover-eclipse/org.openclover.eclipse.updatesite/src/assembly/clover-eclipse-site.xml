<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.1"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.1 https://maven.apache.org/xsd/assembly-2.1.1.xsd">
    <id>site</id>
    <formats>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <!-- The complete p2 repository generated by p2-maven-plugin:
             content.jar, artifacts.jar, p2.index, category.xml, plugins/, features/ -->
        <fileSet>
            <directory>${project.build.directory}/repository</directory>
            <outputDirectory>.</outputDirectory>
        </fileSet>
        <!-- Human-readable extras alongside the repository -->
        <fileSet>
            <directory>${project.build.outputDirectory}</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>README.html</include>
                <include>LICENSE.txt</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>../org.openclover.eclipse.core/src/main/resources/licenses</directory>
            <outputDirectory>licenses</outputDirectory>
        </fileSet>
        <fileSet>
            <directory>../../clover-core/src/main/resources/licenses</directory>
            <outputDirectory>licenses</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>
